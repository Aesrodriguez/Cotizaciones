# PostgreSQL Configuration
POSTGRES_USER=cotizaciones
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=cotizaciones_db

# Backend Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
DATABASE_URL=postgresql://cotizaciones:dev_password_change_me@postgres:5432/cotizaciones_db

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Frontend Configuration
VITE_API_URL=http://localhost:8000
NODE_ENV=development

# Production-specific (for docker-compose.prod.yml)
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=info
# POSTGRES_PASSWORD=strong_production_password_here
# JWT_SECRET=strong_jwt_secret_key_here
# CORS_ORIGINS=https://yourdomain.com
